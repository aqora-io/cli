ARG KUBIMO_MARIMO_IMAGE=ghcr.io/aqora-io/kubimo-marimo:0.1.23

FROM ${KUBIMO_MARIMO_IMAGE}

ARG AQORA_VERSION=0.25.0
USER root
RUN --mount=type=cache,target=/root/.cache/uv,sharing=locked \
    --mount=type=cache,target=/root/.local/share/uv/python,sharing=locked \
  uv pip install --system "aqora-cli==${AQORA_VERSION}"

USER me
WORKDIR /home/me/workspace
RUN <<EOF
aqora new dataset-marimo -s user/workspace -v 0.0.0 .
rm readme.py
uv sync
EOF
